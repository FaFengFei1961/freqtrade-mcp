# ----------------------------------------------------------------------
# freqtrade-mcp — environment configuration template
# Copy to `.env` and edit. `.env` is git-ignored.
# ----------------------------------------------------------------------

# --- Freqtrade REST API (must match user_data/config.json's api_server) ---
FREQTRADE_URL=http://127.0.0.1:8080
FREQTRADE_USERNAME=freqtrader
FREQTRADE_PASSWORD=

# --- Exchange for ccxt direct fetch ---
EXCHANGE_ID=gate
EXCHANGE_MARKET_TYPE=swap

# --- Risk Guardian hard limits (enforced in every write tool) ---
RISK_MAX_LEVERAGE=5.0
RISK_MAX_STAKE_FRACTION=0.10
RISK_DAILY_LOSS_CIRCUIT=-0.10
RISK_TOTAL_DRAWDOWN_CIRCUIT=-0.20
RISK_MIN_24H_VOLUME_USDT=50000000

# --- Default permission mode ---
# One of: plan, ask, auto-small, auto, bypass
PERMISSION_MODE=ask

# --- Path to Freqtrade's user_data directory (shared volume with Docker) ---
# Must be an absolute path. The MCP server writes stop_levels.json here; the
# strategy inside the Freqtrade container reads it from /freqtrade/user_data/.
# Examples:
#   Linux/macOS:  USER_DATA_PATH=/home/yourname/freqtrade-data/user_data
#   Windows:      USER_DATA_PATH=D:\project\freqtrade-data\user_data
USER_DATA_PATH=user_data
