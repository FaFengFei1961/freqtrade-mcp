{
    "_comment_about_this_file": "Copy to user_data/config.json and replace REPLACE_ME values. See README for guidance.",

    "max_open_trades": 50,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.99,
    "position_adjustment_enable": true,
    "max_entry_position_adjustment": -1,
    "fiat_display_currency": "USD",
    "timeframe": "5m",
    "dry_run": true,
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": false,

    "trading_mode": "futures",
    "margin_mode": "isolated",

    "unfilledtimeout": {
        "entry": 525600,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },

    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },

    "exchange": {
        "name": "gate",
        "key": "",
        "secret": "",
        "_comment_keys": "Leave empty for dry-run. For live, fill in your Gate.io API key/secret with trading scope.",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [],
        "pair_blacklist": [
            "(BUSD|USDC|TUSD|FDUSD|USDP|DAI)/USDT:USDT",
            ".*UP/USDT:USDT",
            ".*DOWN/USDT:USDT",
            ".*BULL/USDT:USDT",
            ".*BEAR/USDT:USDT"
        ]
    },

    "pairlists": [
        {
            "method": "VolumePairList",
            "number_assets": 50,
            "sort_key": "quoteVolume",
            "min_value": 5000000,
            "refresh_period": 1800
        },
        {"method": "AgeFilter", "min_days_listed": 30},
        {"method": "PriceFilter", "low_price_ratio": 0.01, "min_price": 0.000001},
        {"method": "SpreadFilter", "max_spread_ratio": 0.005},
        {
            "method": "VolatilityFilter",
            "lookback_days": 7,
            "min_volatility": 0.02,
            "max_volatility": 0.75,
            "refresh_period": 1800
        }
    ],

    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": true,
        "_comment_secrets": "Generate with:  python -c \"import secrets; print(secrets.token_hex(32))\"",
        "jwt_secret_key": "REPLACE_ME_WITH_64_HEX_CHARS",
        "ws_token": "REPLACE_ME_WITH_64_HEX_CHARS",
        "CORS_origins": ["http://127.0.0.1:8080"],
        "username": "freqtrader",
        "password": "REPLACE_ME_WITH_STRONG_PASSWORD"
    },

    "bot_name": "freqtrade_mcp_dryrun",
    "initial_state": "running",
    "force_entry_enable": true,

    "internals": {
        "process_throttle_secs": 5
    },

    "logfile": "/freqtrade/user_data/logs/freqtrade.log",
    "db_url": "sqlite:////freqtrade/user_data/tradesv3.sqlite"
}
